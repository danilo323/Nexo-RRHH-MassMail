# ============================================================
#   NEXO RRHH — .gitignore Completo (Backend + Frontend)
# ============================================================

# ─── PYTHON / FASTAPI (Backend) ─────────────────────────────

# Entornos virtuales — NUNCA subir al repo
.venv_pdf/
.venv/
venv/
env/
ENV/
.env/

# Variables de entorno y secretos — MUY IMPORTANTE no subir
.env
.env.local
.env.production
*.env
secrets.py

# Base de datos SQLite local
*.db
*.sqlite
*.sqlite3

# Caché de Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Distribución / build de Python
dist/
build/
*.egg-info/
*.egg
.eggs/

# Pytest / cobertura de tests
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/
.dmypy.json

# Logs del servidor
*.log
logs/

# Archivos temporales de upload
uploads/
temp_pdfs/


# ─── NODE / REACT / VITE (Frontend) ─────────────────────────

# Dependencias — se instalan con npm install
frontend/node_modules/
node_modules/

# Build de producción
frontend/dist/
dist/

# Cache de Vite
frontend/.vite/
.vite/

# Variables de entorno del frontend
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Logs de npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ─── SISTEMA OPERATIVO ───────────────────────────────────────

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~


# ─── EDITORES E IDEs ─────────────────────────────────────────

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, WebStorm)
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# Sublime Text
*.sublime-project
*.sublime-workspace


# ─── ARCHIVOS SENSIBLES DEL PROYECTO ────────────────────────

# Claves privadas y certificados
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# Tokens y configuraciones OAuth
oauth_credentials.json
token.json
credentials.json

# PDFs de prueba / nóminas reales
*.pdf
test_pdfs/
nomina_real/


# ─── GIT ────────────────────────────────────────────────────

*.orig
*.rej
