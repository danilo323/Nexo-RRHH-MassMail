# Normalizar saltos de línea en Windows
* text=auto

# Archivos de código — siempre LF en el repo
*.py    text eol=lf
*.jsx   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binarios — no tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.db    binary
*.sqlite binary
